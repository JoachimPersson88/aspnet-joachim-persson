@model List<GymPortal.Web.ViewModels.GymClassViewModel>

@{
    ViewData["Title"] = "Pass";
}

<h2>Tillgängliga pass</h2>

@if (TempData["SuccessMessage"] != null)
{
    <p style="color: green;">@TempData["SuccessMessage"]</p>
}

@if (TempData["ErrorMessage"] != null)
{
    <p style="color: red;">@TempData["ErrorMessage"]</p>
}

@if (!Model.Any())
{
    <p>Det finns inga pass just nu.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Namn</th>
                <th>Kategori</th>
                <th>Instruktör</th>
                <th>Tid</th>
                <th>Platser</th>
                <th>Bokning</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var gymClass in Model)
            {
                <tr>
                    <td>@gymClass.Name</td>
                    <td>@gymClass.Category</td>
                    <td>@gymClass.Instructor</td>
                    <td>@gymClass.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@gymClass.SpotsLeft platser kvar</td>
                    <td>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            if (gymClass.SpotsLeft > 0)
                            {
                                <form asp-controller="Booking" asp-action="Create" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="gymClassId" value="@gymClass.Id" />
                                    <button type="submit">Boka</button>
                                </form>
                            }
                            else
                            {
                                <button disabled style="color: gray;">Fullt</button>
                            }
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login">Logga in för att boka</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}