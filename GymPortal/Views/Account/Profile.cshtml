@model GymPortal.Web.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Min profil";
}

<h2>Min profil</h2>

@if (ViewBag.Message != null)
{
    <p style="color: green;">@ViewBag.Message</p>
}

@if (TempData["ErrorMessage"] != null)
{
    <p style="color: red;">@TempData["ErrorMessage"]</p>
}

<form asp-action="Profile" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div>
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="LastName"></label>
        <input asp-for="LastName" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Email"></label>
        <input asp-for="Email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="PhoneNumber"></label>
        <input asp-for="PhoneNumber" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>

    <button type="submit">Spara ändringar</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<hr />

<h3>Ta bort konto</h3>
<p>Detta tar bort ditt konto och kan inte ångras.</p>

<form asp-action="DeleteAccount" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" onclick="return confirm('Är du säker på att du vill ta bort ditt konto?');">
        Ta bort mitt konto
    </button>
</form>