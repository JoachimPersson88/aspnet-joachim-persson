@model List<GymPortal.Web.ViewModels.BookingViewModel>

@{
    ViewData["Title"] = "Mina bokningar";
}

<h2>Mina bokningar</h2>

@if (TempData["SuccessMessage"] != null)
{
    <p style="color: green;">@TempData["SuccessMessage"]</p>
}

@if (TempData["ErrorMessage"] != null)
{
    <p style="color: red;">@TempData["ErrorMessage"]</p>
}

@if (!Model.Any())
{
    <p>Du har inga bokade pass.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Pass</th>
                <th>Kategori</th>
                <th>Instruktör</th>
                <th>Tid</th>
                <th>Bokad</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.ClassName</td>
                    <td>@booking.Category</td>
                    <td>@booking.Instructor</td>
                    <td>@booking.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@booking.BookedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <form asp-controller="Booking" asp-action="Cancel" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookingId" value="@booking.BookingId" />
                            <button type="submit">Avboka</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}